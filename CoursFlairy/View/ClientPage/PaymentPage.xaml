<Page x:Class="CoursFlairy.View.ClientPage.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoursFlairy.View.ClientPage"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="PaymentPage" 
      d:DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Стиль для текстових полів -->
        <Style x:Key="PaymentTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource MainColor20}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="2"
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource MainColor50}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PriceBackgroundColor}">
        <Grid MaxWidth="600" MaxHeight="800" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Payment Details" 
                     FontFamily="Bahnschrift"
                     FontSize="24" 
                     Margin="20,20,20,10"
                     Foreground="{StaticResource MainColor100}"/>

            <!-- Payment Form -->
            <Border Grid.Row="1" 
                    Background="White" 
                    Margin="20,0,20,20" 
                    CornerRadius="10"
                    BorderBrush="{StaticResource MainColor20}"
                    BorderThickness="1">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Amount -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Сума до сплати"
                                 FontFamily="Bahnschrift"
                                 FontSize="14"
                                 Margin="0,0,0,5"
                                 Foreground="{StaticResource HintColor}"/>
                        <TextBlock Text="{Binding Amount, StringFormat={}{0:N2} грн}"
                                 FontFamily="Bahnschrift"
                                 FontSize="24"
                                 Foreground="{StaticResource MainColor100}"/>
                    </StackPanel>

                    <!-- Card Number -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="Номер картки"
                                 FontFamily="Bahnschrift"
                                 FontSize="14"
                                 Margin="0,0,0,5"
                                 Foreground="{StaticResource HintColor}"/>
                        <TextBox x:Name="CardNumberTextBox"
                               Style="{StaticResource PaymentTextBox}"
                               Text="{Binding CardNumber, UpdateSourceTrigger=PropertyChanged}"
                               MaxLength="19"
                               PreviewTextInput="NumberValidationTextBox"
                               PreviewKeyDown="TextBox_PreviewKeyDown"
                               KeyUp="CardNumberTextBox_KeyUp"/>
                    </StackPanel>

                    <!-- Expiry and CVV -->
                    <Grid Grid.Row="2" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Термін дії (ММ/РР)"
                                     FontFamily="Bahnschrift"
                                     FontSize="14"
                                     Margin="0,0,0,5"
                                     Foreground="{StaticResource HintColor}"/>
                            <TextBox x:Name="ExpiryTextBox"
                                   Style="{StaticResource PaymentTextBox}"
                                   Text="{Binding ExpiryDate, UpdateSourceTrigger=PropertyChanged}"
                                   MaxLength="5"
                                   PreviewTextInput="ExpiryValidationTextBox"
                                   PreviewKeyDown="TextBox_PreviewKeyDown"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CVV-код"
                                     FontFamily="Bahnschrift"
                                     FontSize="14"
                                     Margin="0,0,0,5"
                                     Foreground="{StaticResource HintColor}"/>
                            <TextBox x:Name="CvvTextBox"
                                   Style="{StaticResource PaymentTextBox}"
                                   Text="{Binding Cvv, UpdateSourceTrigger=PropertyChanged}"
                                   MaxLength="3"
                                   PreviewTextInput="NumberValidationTextBox"
                                   PreviewKeyDown="TextBox_PreviewKeyDown"/>
                        </StackPanel>
                    </Grid>

                    <!-- Pay Button -->
                    <Button Grid.Row="3" 
                            Content="Оплатити"
                            Command="{Binding PayCommand}"
                            Height="45"
                            Background="{StaticResource MainColor100}"
                            Foreground="White"
                            FontFamily="Bahnschrift"
                            FontSize="16"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Processing Overlay -->
                    <Grid Grid.Row="0" Grid.RowSpan="6" 
                          Background="#80FFFFFF"
                          Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" 
                                  VerticalAlignment="Center">
                            <TextBlock Text="Processing Payment..."
                                     FontFamily="Bahnschrift"
                                     FontSize="18"
                                     Foreground="{StaticResource MainColor100}"
                                     HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" 
                                       Width="200" 
                                       Height="2" 
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
