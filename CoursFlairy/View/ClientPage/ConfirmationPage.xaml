<Page x:Class="CoursFlairy.View.ClientPage.ConfirmationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoursFlairy.View.ClientPage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConfirmationPage">

    <Grid Background="{StaticResource PriceBackgroundColor}">
        <Grid MaxWidth="600" MaxHeight="800" VerticalAlignment="Center">
            <Border Background="White" 
                    Margin="20" 
                    CornerRadius="15"
                    BorderBrush="{StaticResource MainColor20}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" 
                                    ShadowDepth="0" 
                                    Opacity="0.1"/>
                </Border.Effect>

                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Іконка успіху -->
                    <Border Grid.Row="0"
                            Width="90"
                            Height="90"
                            Background="{StaticResource MainColor100}"
                            CornerRadius="45"
                            Margin="0,10,0,25"
                            HorizontalAlignment="Center">
                        <TextBlock Text="✓"
                                 FontSize="48"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>

                    <!-- Заголовок -->
                    <TextBlock Grid.Row="1" 
                             Text="Платіж успішно зараховано!"
                             FontFamily="Bahnschrift"
                             FontSize="26"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource MainColor100}"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             Margin="0,0,0,15"/>

                    <!-- Деталі платежу -->
                    <Border Grid.Row="2" 
                            Background="#F8F9FA"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text="Деталі платежу:"
                                     FontFamily="Bahnschrift"
                                     FontSize="16"
                                     Foreground="{StaticResource HintColor}"
                                     Margin="0,0,0,10"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Сума: "
                                         FontFamily="Bahnschrift"
                                         FontSize="18"
                                         Foreground="{StaticResource MainColor100}"/>
                                         
                                <TextBlock Grid.Column="1"
                                         Text="{Binding Amount, StringFormat={}{0:N2} грн}"
                                         FontFamily="Bahnschrift"
                                         FontSize="18"
                                         FontWeight="SemiBold"
                                         Foreground="{StaticResource MainColor100}"
                                         HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка повернення -->
                    <Button Grid.Row="3" 
                            Content="Повернутися на головну"
                            Command="{Binding ReturnHomeCommand}"
                            Height="50"
                            Background="{StaticResource MainColor100}"
                            FontFamily="Bahnschrift"
                            FontSize="16"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page> 