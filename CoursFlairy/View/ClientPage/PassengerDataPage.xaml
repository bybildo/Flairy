<Page x:Class="CoursFlairy.View.ClientPage.PassengerDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoursFlairy.View.ClientPage"
      xmlns:ui="clr-namespace:CoursFlairy.View.UI"
      xmlns:searchconverter="clr-namespace:CoursFlairy.ViewModel.Converter.SearchPage"
      xmlns:mainconverter="clr-namespace:CoursFlairy.ViewModel.Converter.MainWindow"
      xmlns:businessconverter="clr-namespace:CoursFlairy.ViewModel.Converter.Bussines"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="PassengerDataPage">

    <Page.Resources>
        <searchconverter:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>
        <mainconverter:OpacityToVisiblityConverter x:Key="OpacityToVisiblityConverter"/>
        <businessconverter:BoolToVisiblityConverter x:Key="BoolToVisiblityConverter"/>
        <businessconverter:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
        <businessconverter:BoolToTextConverter x:Key="BoolToTextConverter"/>
    </Page.Resources>

    <ScrollViewer Grid.Column="1" VerticalAlignment="Top" VerticalScrollBarVisibility="Hidden" Focusable="False">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition Width="0.2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Grid.Column="1">
                <Grid Height="200" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="8*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Border Background="White" CornerRadius="10" Grid.Row="1" Grid.Column="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="0.4" Color="{DynamicResource Shadow}" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                <Run Text="{Binding DepartureCity, StringFormat={}{0:U}}" FontSize="24" FontWeight="Bold"/>
                <Run Text=" - " FontSize="24" FontWeight="Bold"/>
                <Run Text="{Binding ArrivalCity, StringFormat={}{0:U}}" FontSize="24" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,5,0,0">
                <Run Text="{Binding DepartureIcao, StringFormat={}{0:l}}" FontSize="16" Foreground="#666666"/>
                <Run Text=" - " FontSize="16" Foreground="#666666"/>
                <Run Text="{Binding ArrivalIcao, StringFormat={}{0:l}}" FontSize="16" Foreground="#666666"/>
                            </TextBlock>
                            <Grid Margin="0,10,0,0" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Departure Time -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding DepartureTime, StringFormat={}{0:HH:mm}}" FontSize="20" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding DepartureTime, StringFormat={}{0:dd.MM.yyyy}}" FontSize="16" Foreground="#666666"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Arrow or Separator -->
                                <TextBlock Grid.Column="1" 
                           Text="-" 
                           FontSize="20" 
                           Margin="15,0,15,0" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"
                           Foreground="#666666"/>

                                <!-- Arrival Time -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding ArrivalTime, StringFormat={}{0:HH:mm}}" FontSize="20" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding ArrivalTime, StringFormat={}{0:dd.MM.yyyy}}" FontSize="16" Foreground="#666666"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
                <ItemsControl x:Name="PassengersItemsControl" ItemsSource="{Binding Passengers}" Margin="0, 20, 0, 0" Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Border Margin="3,0,3,30" 
                    Background="White" 
                    CornerRadius="15"
                    Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0.4" Color="{DynamicResource Shadow}" Opacity="0.5" />
                                    </Border.Effect>
                                </Border>
                                <StackPanel Margin="0,0,0,30">
                                    <Grid Margin="23,23,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" FontSize="18" 
                                                  FontWeight="SemiBold">
                                            <Run Text="Пасажир "/>
                                            <Run Text="{Binding PassengerNumber}"/>
                                            <Run Text=" • "/>
                                            <Run Text="{Binding PassengerClass}" 
                                                 Foreground="{DynamicResource MainColor100}"/>
                                        </TextBlock>
                                        
                                        <!-- Кнопка швидкого заповнення -->
                                        <Button Grid.Column="1"
                                                x:Name="QuickFillButton"
                                                Content="Заповнити моїми даними"
                                                FontSize="12"
                                                Padding="10,5"
                                                Background="{DynamicResource MainColor100}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Margin="10,0,23,0"
                                                Click="QuickFillButton_Click"
                                                Tag="{Binding}"
                                                Visibility="{Binding DataContext.ShowQuickFillButtons, 
                                                           RelativeSource={RelativeSource AncestorType=Page}, 
                                                           Converter={StaticResource BoolToVisiblityConverter}}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="5"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                    <ui:UserPassportData Height="320" 
                                                        Margin="23" 
                                                        x:Name="PassportData"
                                                        DataContext="{Binding}"
                                                        Loaded="UserPassportData_Loaded"/>

                                    <!-- Baggage Section -->
                                    <StackPanel Margin="23,0,23,10">
                                        <TextBlock Text="Багаж" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                        
                                        <!-- Backpack Info -->
                                        <Border Background="#F8F9FA" 
                                                CornerRadius="8" 
                                                Padding="15,12">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="40" Height="40" 
                                                            Background="{DynamicResource MainColor20}" 
                                                            CornerRadius="8">
                                                        <Path Stretch="Uniform" Fill="{DynamicResource MainColor100}"  Width="24" Height="24" Data="{DynamicResource backpack}"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                        <TextBlock Text="Ручна поклажа" 
                                                                 FontSize="16" 
                                                                 FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding BackpackIncluded, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Дозволено|Заборонено'}" 
                                                                 FontSize="14" 
                                                                 Foreground="#666666"
                                                                 Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Baggage Option -->
                                        <Border Background="#F8F9FA" 
                                                CornerRadius="8" 
                                                Padding="15,12"
                                                Margin="0,10,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="40" Height="40" 
                                                        Background="{DynamicResource MainColor20}" 
                                                        CornerRadius="8">
                                                    <Path Stretch="Uniform" Fill="{DynamicResource MainColor100}" Width="24" Height="24" Data="{DynamicResource big suitcase}"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                    <TextBlock Text="Багаж" 
                                                             FontSize="16" 
                                                             FontWeight="SemiBold"/>
                                                    <TextBlock Text="До 23 кг" 
                                                             FontSize="14" 
                                                             Foreground="#666666"
                                                             Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" 
                                                          Orientation="Horizontal" 
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding FormattedBaggagePrice}"
                                                             FontSize="16"
                                                             FontWeight="SemiBold"
                                                             Foreground="{DynamicResource MainColor100}"
                                                             Margin="0,0,15,0"
                                                             VerticalAlignment="Center"/>
                                                    
                                                    <CheckBox IsChecked="{Binding HasBaggage}"
                                                              VerticalAlignment="Center"
                                                              IsEnabled="{Binding BaggageAvailable}">
                                                        <CheckBox.Style>
                                                            <Style TargetType="CheckBox">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="CheckBox">
                                                                            <Border x:Name="border" 
                                                                                    Background="White"
                                                                                    BorderBrush="{DynamicResource MainColor100}"
                                                                                    BorderThickness="2"
                                                                                    CornerRadius="4"
                                                                                    Width="22" 
                                                                                    Height="22">
                                                                                <Path x:Name="checkMark"
                                                                                      Data="M9.5,0.5L11,2L5,8L0,3L1.5,1.5L5,5L9.5,0.5Z"
                                                                                      Fill="{DynamicResource MainColor100}"
                                                                                      Stretch="Uniform"
                                                                                      Width="12"
                                                                                      Height="12"
                                                                                      Visibility="Collapsed"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource MainColor20}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </CheckBox.Style>
                                                    </CheckBox>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding FormattedPrice}"
                                             FontSize="16"
                                             FontWeight="SemiBold"
                                             Foreground="{DynamicResource MainColor100}"
                                             Margin="23,0,23,23"
                                             HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Email and Payment Section -->
                <Grid Margin="3,0,3,30">
                    <Border Background="White" 
                            CornerRadius="15"
                            Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="0.4" Color="{DynamicResource Shadow}" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                    
                    <StackPanel Margin="23">
                        <Border x:Name="emailBorder" 
                                BorderBrush="{DynamicResource MainColor20}" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Width="300"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20">
                            <Grid Margin="10,0,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Вкажіть пошту" 
                                         FontSize="17" 
                                         Margin="2,0,0,0"  
                                         Foreground="{DynamicResource HintColor}" 
                                         Opacity="0.6" 
                                         VerticalAlignment="Center" 
                                         Visibility="{Binding ElementName=emailTextBox, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Disabled" 
                                            HorizontalScrollBarVisibility="Hidden" 
                                            PanningMode="HorizontalOnly">
                                    <TextBox x:Name="emailTextBox" 
                                           Foreground="{DynamicResource Black}" 
                                           FontSize="19" 
                                           FontFamily="Bahnschrift" 
                                           MaxLength="100" 
                                           TextChanged="emailAnimation"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           Height="35"
                                           VerticalContentAlignment="Center"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Points Panel -->
                        <StackPanel x:Name="pointsInfoPanel" 
                                  Visibility="Collapsed"
                                  Width="300"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="{Binding AvailablePoints, StringFormat=Доступно балів: {0}}"
                                         FontFamily="Bahnschrift"
                                         FontSize="14"
                                         Margin="0,0,10,0"
                                         Foreground="{StaticResource MainColor100}"/>
                                         
                                <CheckBox Grid.Column="1"
                                          Content="Використати бали"
                                          FontFamily="Bahnschrift"
                                          FontSize="14"
                                          IsChecked="{Binding UsePoints}"
                                          IsEnabled="{Binding AvailablePoints, Converter={StaticResource GreaterThanZeroConverter}}">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="CheckBox">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border x:Name="border" 
                                                                    Background="White"
                                                                    BorderBrush="{DynamicResource MainColor100}"
                                                                    BorderThickness="2"
                                                                    CornerRadius="4"
                                                                    Width="22" 
                                                                    Height="22">
                                                                <Path x:Name="checkMark"
                                                                      Data="M9.5,0.5L11,2L5,8L0,3L1.5,1.5L5,5L9.5,0.5Z"
                                                                      Fill="{DynamicResource MainColor100}"
                                                                      Stretch="Uniform"
                                                                      Width="12"
                                                                      Height="12"
                                                                      Visibility="Collapsed"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="1"
                                                                     Text="{TemplateBinding Content}"
                                                                     Margin="10,0,0,0"
                                                                     VerticalAlignment="Center"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MainColor20}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                            </Grid>
                            
                            <TextBlock Text="{Binding FinalAmount, StringFormat=Сума до сплати: {0:N2} грн}"
                                     FontFamily="Bahnschrift"
                                     FontSize="16"
                                     Margin="0,10,0,0"
                                     Foreground="{StaticResource MainColor100}"/>
                        </StackPanel>

                        <!-- Total Sum and Payment Button -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Margin="0,0,20,0">
                                <Run Text="Загальна сума: " FontSize="18"/>
                                <Run Text="{Binding TotalSum}" 
                                     FontSize="20" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource MainColor100}"/>
                                <Run Text="грн"
                                     FontSize="20" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource MainColor100}"/>
                            </TextBlock>

                            <Button x:Name="PaymentButton"
                                    Grid.Column="1"
                                    Content="Сплатити"
                                    FontSize="18"
                                    Padding="30,12"
                                    Background="{DynamicResource MainColor100}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="PaymentButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
