<Page x:Class="CoursFlairy.View.ClientPage.PassengerDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoursFlairy.View.ClientPage"
      xmlns:ui="clr-namespace:CoursFlairy.View.UI"
      xmlns:searchconverter="clr-namespace:CoursFlairy.ViewModel.Converter.SearchPage"
      xmlns:mainconverter="clr-namespace:CoursFlairy.ViewModel.Converter.MainWindow"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="PassengerDataPage">

    <Page.Resources>
        <searchconverter:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>
        <mainconverter:OpacityToVisiblityConverter x:Key="OpacityToVisiblityConverter"/>
    </Page.Resources>

    <ScrollViewer Grid.Column="1" VerticalAlignment="Top" VerticalScrollBarVisibility="Hidden" Focusable="False">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition Width="0.2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Grid.Column="1">
                <Grid Height="200" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="8*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Border Background="White" CornerRadius="10" Grid.Row="1" Grid.Column="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="0.4" Color="{DynamicResource Shadow}" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                <Run Text="{Binding DepartureCity, StringFormat={}{0:U}}" FontSize="24" FontWeight="Bold"/>
                <Run Text=" - " FontSize="24" FontWeight="Bold"/>
                <Run Text="{Binding ArrivalCity, StringFormat={}{0:U}}" FontSize="24" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,5,0,0">
                <Run Text="{Binding DepartureIcao, StringFormat={}{0:l}}" FontSize="16" Foreground="#666666"/>
                <Run Text=" - " FontSize="16" Foreground="#666666"/>
                <Run Text="{Binding ArrivalIcao, StringFormat={}{0:l}}" FontSize="16" Foreground="#666666"/>
                            </TextBlock>
                            <Grid Margin="0,10,0,0" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Departure Time -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding DepartureTime, StringFormat={}{0:HH:mm}}" FontSize="20" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding DepartureTime, StringFormat={}{0:dd.MM.yyyy}}" FontSize="16" Foreground="#666666"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Arrow or Separator -->
                                <TextBlock Grid.Column="1" 
                           Text="-" 
                           FontSize="20" 
                           Margin="15,0,15,0" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"
                           Foreground="#666666"/>

                                <!-- Arrival Time -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding ArrivalTime, StringFormat={}{0:HH:mm}}" FontSize="20" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="{Binding ArrivalTime, StringFormat={}{0:dd.MM.yyyy}}" FontSize="16" Foreground="#666666"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
                <ItemsControl ItemsSource="{Binding Passengers}" Margin="0, 20, 0, 0" Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Border Margin="3,0,3,30" 
                    Background="White" 
                    CornerRadius="15"
                    Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0.4" Color="{DynamicResource Shadow}" Opacity="0.5" />
                                    </Border.Effect>
                                </Border>
                                <StackPanel Margin="0,0,0,30">
                                    <TextBlock FontSize="18" 
                              FontWeight="SemiBold" 
                              Margin="23,23,0,5">
                                        <Run Text="Пасажир "/>
                                        <Run Text="{Binding PassengerNumber}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding PassengerClass}" 
                                             Foreground="{DynamicResource MainColor100}"/>
                                    </TextBlock>
                                    <ui:UserPassportData Height="320" 
                                                        Margin="23" 
                                                        x:Name="PassportData"
                                                        DataContext="{Binding}"
                                                        Loaded="UserPassportData_Loaded"/>
                                    <TextBlock Text="{Binding FormattedPrice}"
                                             FontSize="16"
                                             FontWeight="SemiBold"
                                             Foreground="{DynamicResource MainColor100}"
                                             Margin="23,0,23,23"
                                             HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Email and Payment Section -->
                <Grid Margin="3,0,3,30">
                    <Border Background="White" 
                            CornerRadius="15"
                            Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="0.4" Color="{DynamicResource Shadow}" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                    
                    <StackPanel Margin="23">
                        <!-- Email Input -->
                        <TextBlock Text="Email:" 
                                 FontFamily="{DynamicResource BlackerSans Pro It Variable}" 
                                 FontWeight="Light" 
                                 FontSize="16"
                                 Foreground="{DynamicResource Black}"
                                 Margin="0,0,0,10"/>
                        
                        <Border x:Name="emailBorder" 
                                BorderBrush="{DynamicResource MainColor20}" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Width="300"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20">
                            <Grid Margin="10,0,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Вкажіть пошту" 
                                         FontSize="17" 
                                         Margin="2,0,0,0"  
                                         Foreground="{DynamicResource HintColor}" 
                                         Opacity="0.6" 
                                         VerticalAlignment="Center" 
                                         Visibility="{Binding ElementName=email, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Disabled" 
                                            HorizontalScrollBarVisibility="Hidden" 
                                            PanningMode="HorizontalOnly">
                                    <TextBox x:Name="email" 
                                           Foreground="{DynamicResource Black}" 
                                           FontSize="19" 
                                           FontFamily="Bahnschrift" 
                                           MaxLength="100" 
                                           TextChanged="emailAnimation"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           Height="35"
                                           VerticalContentAlignment="Center"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Total Sum and Payment Button -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Margin="0,0,20,0">
                                <Run Text="Загальна сума: " FontSize="18"/>
                                <Run Text="{Binding TotalSum}" 
                                     FontSize="20" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource MainColor100}"/>
                                <Run Text="грн"
                                     FontSize="20" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource MainColor100}"/>
                            </TextBlock>

                            <Button x:Name="PaymentButton"
                                    Grid.Column="1"
                                    Content="Сплатити"
                                    FontSize="18"
                                    Padding="30,12"
                                    Background="{DynamicResource MainColor100}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="PaymentButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
