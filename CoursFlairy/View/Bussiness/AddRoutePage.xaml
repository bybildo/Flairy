<Page x:Class="CoursFlairy.View.Bussiness.AddRoutePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoursFlairy.View.Bussiness"
      xmlns:converter="clr-namespace:CoursFlairy.ViewModel.Converter.Bussines"
      xmlns:convertersearch="clr-namespace:CoursFlairy.ViewModel.Converter.SearchPage"
      xmlns:UI="clr-namespace:CoursFlairy.View.UI" Loaded="Page_Loaded"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="1040"
      Title="AddRoutePage">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="30"/>
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border 
                      Background="Transparent" 
                      BorderBrush="Transparent" 
                      BorderThickness="0">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource White}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MainColor20}"/>
            <Setter Property="Foreground" Value="Navy"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
        </Style>

        <Style TargetType="Border" x:Key="ButtonStyle">
            <Setter Property="Background" Value="{DynamicResource White}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)" To="0.6"/>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)" To="5"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>

                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)" To="0.35"/>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)" To="4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="ButtonStyleT">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
            <Setter Property="Foreground" Value="{DynamicResource MainColor100}"/>
        </Style>

        <convertersearch:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>
    </Page.Resources>

    <Grid Name="AllGrid" Background="{DynamicResource White}" DataContext="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=Page, Mode=FindAncestor}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Grid Grid.ColumnSpan="100" Grid.RowSpan="100" Background="Transparent" MouseDown="Page_MouseDown"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.05*"/>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition Width="0.4*"/>
                <ColumnDefinition Width="0.05*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource ButtonStyle}" PreviewMouseDown="BackAddPlane_PreviewMouseDown">
                <Viewbox Margin="8">
                    <TextBlock Text="Назад" FontFamily="Bahnschrift" Style="{StaticResource ButtonStyleT}"/>
                </Viewbox>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>

            <Border BorderBrush="{DynamicResource MainColor20}" Background="Transparent" BorderThickness="1" Grid.Column="3" Grid.Row="1" CornerRadius="6">
                <Grid Margin="5, 0, 5, 0">
                    <TextBlock Text="Назва маршруту" Grid.Column="1" FontSize="20" Margin="2,0,0,0" Foreground="{DynamicResource HintColor}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=PlaneNameTb, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                    <ScrollViewer  Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                        <TextBox Name="PlaneNameTb" Text="{Binding RouteName,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource Black}" MaxLength="255" FontFamily="Bahnschrift" FontSize="25"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Name="AddRouteButton" Visibility="Collapsed" Grid.Column="5" Grid.Row="1" Style="{StaticResource ButtonStyle}" PreviewMouseDown="AddRoute_PreviewMouseDown">
                <Viewbox Margin="8">
                    <TextBlock Text="Додати" FontFamily="Bahnschrift" Style="{StaticResource ButtonStyleT}"/>
                </Viewbox>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>

        </Grid>
        <Line Stroke="Navy" StrokeThickness="1" VerticalAlignment="Bottom" X2="{Binding ElementName=MainGrid, Path=ActualWidth}"/>

        <Grid Name="MainGrid" MouseDown="Page_MouseDown" Grid.Row="1">
            <Grid.RowDefinitions>
                <!--<RowDefinition Height="0.2*"/>
                <RowDefinition Height="0.9*"/>
                <RowDefinition Height="0.2*"/>
                <RowDefinition Height="1.4*"/>
                <RowDefinition Height="0.1*"/>-->
                <RowDefinition Height="0.8*"/>
                <RowDefinition Height="0.9*"/>
                <RowDefinition Height="0*"/>
                <RowDefinition Height="0*"/>
                <RowDefinition Height="1.10*"/>
            </Grid.RowDefinitions>

            <Grid Name="AirportGrid" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.25*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition Width="0.1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="0.25*"/>
                </Grid.ColumnDefinitions>

                <Button Name="HidenButton" Opacity="0" FocusVisualStyle="{x:Null}"/>
                <UI:AiroportPicker x:Name="AirportPicker" Grid.Column="1" Grid.ColumnSpan="2" Visibility="Visible" DepartureSelect="AiroportPicker_DepartureSelect" DepartureUnselect="AiroportPicker_DepartureUnselect" ArrivalSelect="AiroportPicker_ArrivalSelect" ArrivalUnselect="AiroportPicker_ArrivalUnselect"/>
                <Border Grid.Column="1" Margin="5" Background="{DynamicResource White}" CornerRadius="10"/>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.75*"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="0.8*"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="0.77*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="12*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!--Із-->
                    <Border Name="DepartureBorder" Grid.Row="1" Grid.Column="1" CornerRadius="10" BorderThickness="1.8" BorderBrush="{DynamicResource MainColor20}"/>
                    <Grid Grid.Row="1" Grid.Column="1" PreviewMouseDown="ToDeparture">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.3*"/>
                            <ColumnDefinition Width="8*"/>
                            <ColumnDefinition Width="0.3*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Аеропорт 1" Grid.Column="1" FontSize="22" Margin="2,0,0,0" Foreground="{DynamicResource HintColor}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=AirportPicker, Path=SearchDepartureField, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                        <ScrollViewer  Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                            <TextBox Name="DepartureTextBox" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Foreground="{DynamicResource Black}" MaxLength="200" FontFamily="Bahnschrift" FontSize="25" Text="{Binding ElementName=AirportPicker, Path=SearchDepartureField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </ScrollViewer>
                    </Grid>

                    <!--До-->
                    <Border Name="ArrivalBorder" Grid.Row="3" Grid.Column="1" CornerRadius="10" BorderThickness="1.8" BorderBrush="{DynamicResource MainColor20}"/>
                    <Grid Grid.Row="3" Grid.Column="1" PreviewMouseDown="ToArrival">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.3*"/>
                            <ColumnDefinition Width="8*"/>
                            <ColumnDefinition Width="0.3*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Аеропорт 2" Grid.Column="1" FontSize="22" Margin="2,0,0,0" Foreground="{DynamicResource HintColor}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=AirportPicker, Path=SearchArrivalField, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                        <ScrollViewer  Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                            <TextBox Name="ArrivalTextBox" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus" Foreground="{DynamicResource Black}" MaxLength="200" FontFamily="Bahnschrift" FontSize="25" Text="{Binding ElementName=AirportPicker, Path=SearchArrivalField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <Grid Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2.15*"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="2.17*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="23*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="5, -10, 5, -10" Background="{DynamicResource White}" CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="0.3" Color="{DynamicResource Shadow}" Direction="270" Opacity="0.3" />
                        </Border.Effect>
                    </Border>

                    <Border Name="PlaneBorder" Grid.Row="1" Grid.Column="1" CornerRadius="10" BorderThickness="1.8" BorderBrush="{DynamicResource MainColor20}"/>
                    <Grid Grid.Row="1" Grid.Column="1" PreviewMouseDown="ToArrival">
                        <Grid Margin="10, 0, 10, 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="7*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Введіть ім'я літака" FontSize="21" Margin="2,0,0,0"  Foreground="{DynamicResource HintColor}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=planenametb, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                            <ScrollViewer Margin="0,0,0,-2" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                                <Grid>
                                    <TextBlock Text="{Binding PlaneHint,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource HintColor}" FontSize="24" FontFamily="Bahnschrift" Opacity="0.6" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    <TextBox PreviewKeyDown="KeyControl" Name="planenametb" Text="{Binding PlaneName,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource Black}" FontSize="24" FontFamily="Bahnschrift" MaxLength="100"/>
                                </Grid>
                            </ScrollViewer>

                            <Path x:Name="PlaneButton" Visibility="Hidden" Grid.Column="2" Data="{DynamicResource tabButton}" Fill="{DynamicResource MainColor100}" Stretch="Uniform" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Name="DownGrid" Grid.Row="3" SizeChanged="MainGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.26*"/>
                    <ColumnDefinition Width="2.6*"/>
                    <ColumnDefinition Width="0.84*"/>
                    <ColumnDefinition Width="3.4*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{DynamicResource White}" Grid.Column="1" CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="0.3" Color="{DynamicResource Shadow}" Direction="270" Opacity="0.3" />
                    </Border.Effect>
                </Border>

                <!--Меню нижнє ліве-->
                <Grid Name="SeatsGrid" Grid.Column="1">
                    <Grid.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="FontFamily" Value="Bahnschrift"/>
                            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown"/>
                            <Setter Property="Foreground" Value="{DynamicResource MainColor100}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                                            <ScrollViewer x:Name="PART_ContentHost" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Bahnschrift"/>
                            <Setter Property="Foreground" Value="{DynamicResource MainColor100}"/>
                        </Style>
                    </Grid.Resources>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.6*"/>
                        <ColumnDefinition Width="0*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="7"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Setter Property="Background" Value="{DynamicResource White}"/>
                                <EventSetter Event="PreviewMouseDown" Handler="SeatsBorder_PreviewMouseDown"/>
                                <Setter Property="Margin" Value="0, 0, 1, 10"/>
                                <Setter Property="Height" Value="{Binding SeatButtonSize}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="UseLayoutRounding" Value="True"/>
                                <Setter Property="SnapsToDevicePixels" Value="True"/>
                            </Style>

                            <Style TargetType="Path">
                                <Setter Property="Margin" Value="5, 5, 6, 5"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Stroke" Value="{Binding Path=Fill, RelativeSource={RelativeSource Self}}"/>
                                <Setter Property="StrokeThickness" Value="0.6"/>
                            </Style>
                        </Grid.Resources>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                            <Border Name="EconomBorder" Grid.Column="1" BorderBrush="{DynamicResource EconomColor}">
                                <Path Stretch="Uniform" Data="{DynamicResource adult 1}" Fill="{DynamicResource EconomColor}"/>
                            </Border>

                            <Border Name="BussinessBorder" Grid.Column="1" BorderBrush="{DynamicResource BussinessColor}">
                                <Path Stretch="Uniform" Data="{DynamicResource adult 2}" Fill="{DynamicResource BussinessColor}"/>
                            </Border>

                            <Border Name="FirstBorder" Grid.Column="1" BorderBrush="{DynamicResource FirstColor}">
                                <Path Stretch="Uniform" Data="{DynamicResource adult 3}" Fill="{DynamicResource FirstColor}"/>
                            </Border>

                            <Border Name="SuitcaseBorder" Grid.Column="1" BorderBrush="LimeGreen" Background="LimeGreen" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                                <Path Stretch="Uniform" Data="{DynamicResource suitcase}" Fill="{DynamicResource White}"/>
                                <Border.RenderTransform>
                                    <RotateTransform Angle="180"/>
                                </Border.RenderTransform>
                            </Border>
                        </StackPanel>
                        <Line Grid.Column="2" Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" Grid.RowSpan="3" StrokeThickness="1.3" Opacity="0.9" Stroke="{DynamicResource MainColor20}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Column="1" DataContext="{Binding ClassesPrices}">
                        <Grid.Resources>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{DynamicResource MainColor20}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Grid.Column" Value="1"/>
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Grid.Resources>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="0.2*"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="0.6*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="0.2*"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="0.6*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="0.2*"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="0.6*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="0.2*"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>

                        <Viewbox Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left">
                            <TextBlock Text="Дорослі"/>
                        </Viewbox>

                        <Border Grid.Row="3"/>
                        <Grid Grid.Row="3" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="2.3*"/>
                                <ColumnDefinition Width="0.1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="4*"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" IsEnabled="False">
                                <Viewbox>
                                    <TextBox Text="{Binding AdultPercent, Mode=OneWay}" Foreground="{DynamicResource MainColor20}" PreviewTextInput="NumberPercentTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="x"  Foreground="{DynamicResource MainColor20}"/>
                                </Viewbox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center">
                                <Viewbox>
                                    <TextBox Text="{Binding AdultMoney, Mode=TwoWay}" PreviewTextInput="NumberMoneyTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="₴"/>
                                </Viewbox>
                            </StackPanel>
                            <Line Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" Grid.RowSpan="3" StrokeThickness="1.3" Opacity="0.9" Stroke="{DynamicResource MainColor20}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Viewbox Grid.Column="1" Grid.Row="5" HorizontalAlignment="Left">
                            <TextBlock Text="Пенсіонери"/>
                        </Viewbox>

                        <Border Grid.Row="7"/>
                        <Grid Grid.Row="7" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="2.3*"/>
                                <ColumnDefinition Width="0.1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="4*"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center">
                                <Viewbox>
                                    <TextBox Text="{Binding PensionerPercent, Mode=TwoWay}" PreviewTextInput="NumberPercentTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="x"/>
                                </Viewbox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center">
                                <Viewbox>
                                    <TextBox Text="{Binding PensionerMoney, Mode=TwoWay}" PreviewTextInput="NumberMoneyTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="₴"/>
                                </Viewbox>
                            </StackPanel>

                            <Line Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" Grid.RowSpan="3" StrokeThickness="1.3" Opacity="0.9" Stroke="{DynamicResource MainColor20}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Viewbox Grid.Column="1" Grid.Row="9" HorizontalAlignment="Left">
                            <TextBlock Text="Діти"/>
                        </Viewbox>

                        <Border Grid.Row="11"/>
                        <Grid Grid.Row="11" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="2.3*"/>
                                <ColumnDefinition Width="0.1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="4*"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center">
                                <Viewbox>
                                    <TextBox Text="{Binding ChildPercent, Mode=TwoWay}" PreviewTextInput="NumberPercentTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="x"/>
                                </Viewbox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center">
                                <Viewbox>
                                    <TextBox Text="{Binding ChildMoney, Mode=TwoWay}" PreviewTextInput="NumberMoneyTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="₴"/>
                                </Viewbox>
                            </StackPanel>

                            <Line Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" Grid.RowSpan="3" StrokeThickness="1.3" Opacity="0.9" Stroke="{DynamicResource MainColor20}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Viewbox Grid.Column="1" Grid.Row="13" HorizontalAlignment="Left">
                            <TextBlock Text="Немовлята"/>
                        </Viewbox>

                        <Border Grid.Row="15"/>
                        <Grid Grid.Row="15" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="2.3*"/>
                                <ColumnDefinition Width="0.1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="4*"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center">
                                <Viewbox>
                                    <TextBox Text="{Binding BabyPercent, Mode=TwoWay}" PreviewTextInput="NumberPercentTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="x"/>
                                </Viewbox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center">
                                <Viewbox>
                                    <TextBox Text="{Binding BabyMoney, Mode=TwoWay}" PreviewTextInput="NumberMoneyTextBox_PreviewTextInput"/>
                                </Viewbox>
                                <Viewbox Margin="-2, 0, 0, 0">
                                    <TextBlock Text="₴"/>
                                </Viewbox>
                            </StackPanel>

                            <Line Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" Grid.RowSpan="3" StrokeThickness="1.3" Opacity="0.9" Stroke="{DynamicResource MainColor20}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>

                    <Grid Name="LaggageGrid" Grid.Column="2" DataContext="{Binding ClassesPrices}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="2.15*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="0*"/>
                            <RowDefinition Height="2.35*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Column="1" Grid.Row="1" ToolTip="Чи дозволена ручна поклажа" ToolTipService.InitialShowDelay="300" ToolTipService.ShowDuration="1500" PreviewMouseDown="BackPack_PreviewMouseDown">
                            <Border CornerRadius="5" Background="{DynamicResource White}" Style="{StaticResource ButtonStyle}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.3" Color="{DynamicResource Shadow}" Direction="270" Opacity="0.3" />
                                </Border.Effect>
                            </Border>

                            <Path Name="Backpack" Stretch="Uniform" Data="{DynamicResource backpack}" Fill="{DynamicResource HintColor}" Margin="10"/>
                        </Grid>

                        <Grid Grid.Column="3" Grid.Row="1" PreviewMouseDown="BigSuitcase_PreviewMouseDown" ToolTip="Літак може перевозити багаж" ToolTipService.InitialShowDelay="300" ToolTipService.ShowDuration="1500">
                            <Border CornerRadius="5" Background="{DynamicResource White}" Style="{StaticResource ButtonStyle}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.25" Color="{DynamicResource Shadow}" Direction="270" Opacity="0.3" />
                                </Border.Effect>
                            </Border>

                            <Path Name="BigSuitcase" Stretch="Uniform" Data="{DynamicResource big suitcase}" StrokeThickness="0.4" Stroke="{DynamicResource HintColor}" Margin="7"/>
                        </Grid>

                        <Grid Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3">
                            <Grid.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="Height" Value="{Binding BaggagePrice, RelativeSource={RelativeSource AncestorType=Page}}"/>
                                    <Setter Property="Margin" Value="0, -1, 0, 15"/>
                                    <Setter Property="BorderThickness" Value="1.2"/>
                                    <Setter Property="Grid.Column" Value="1"/>
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Grid.Resources>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>


                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Border Visibility="{Binding ElementName=EconomBorder, Path=Visibility}" BorderBrush="{DynamicResource EconomColor}">
                                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" Margin="2">
                                        <Viewbox>
                                            <TextBox Text="{Binding PensionerMoney, Mode=TwoWay}" PreviewTextInput="NumberMoneyTextBox_PreviewTextInput" MaxLength="8"/>
                                            <!-- Використовуєм бо подібна логіка -->
                                        </Viewbox>
                                        <Viewbox Margin="-2, 0, 0, 0">
                                            <TextBlock Text="₴"/>
                                        </Viewbox>
                                    </StackPanel>
                                </Border>

                                <Border Visibility="{Binding ElementName=BussinessBorder, Path=Visibility}" BorderBrush="{DynamicResource BussinessColor}">
                                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" Margin="2">
                                        <Viewbox>
                                            <TextBox Text="{Binding ChildMoney, Mode=TwoWay}" PreviewTextInput="NumberMoneyTextBox_PreviewTextInput" MaxLength="8"/>
                                            <!-- Пропускаєм Adult бо він міняє ціну всім -->
                                        </Viewbox>
                                        <Viewbox Margin="-2, 0, 0, 0">
                                            <TextBlock Text="₴"/>
                                        </Viewbox>
                                    </StackPanel>
                                </Border>

                                <Border Visibility="{Binding ElementName=FirstBorder, Path=Visibility}" BorderBrush="{DynamicResource FirstColor}">
                                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" Margin="2">
                                        <Viewbox>
                                            <TextBox Text="{Binding BabyMoney, Mode=TwoWay}" PreviewTextInput="NumberMoneyTextBox_PreviewTextInput" MaxLength="8"/>
                                        </Viewbox>
                                        <Viewbox Margin="-2, 0, 0, 0">
                                            <TextBlock Text="₴"/>
                                        </Viewbox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <!--Меню нижнє праве-->
                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.9*"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="1.1*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.6*"/>
                            <RowDefinition Height="0.6*"/>
                            <RowDefinition Height="0.2*"/>
                            <RowDefinition Height="0.5*"/>
                            <RowDefinition Height="0.3*"/>
                            <RowDefinition Height="0.6*"/>
                            <RowDefinition Height="0.6*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Center">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Bahnschrift"/>
                                    <Setter Property="Foreground" Value="{DynamicResource MainColor100}"/>
                                </Style>
                            </StackPanel.Resources>

                            <Viewbox>
                                <TextBlock Text="Переліт займає: "/>
                            </Viewbox>
                            <Viewbox>
                                <TextBlock Text="{Binding TimeString}"/>
                            </Viewbox>
                        </StackPanel>
                        <Slider Minimum="0" Maximum="1440" Value="{Binding Time, Mode=TwoWay}" Margin="20, 0, 20, 0" Grid.Row="3">
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.ColumnSpan="3" Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType=Slider}}" Background="#e0e0e0" VerticalAlignment="Center" CornerRadius="10" />

                                        <Track Grid.Column="1" x:Name="PART_Track">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType=Slider}}" IsEnabled="False" BorderThickness="0">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Background="{DynamicResource ForRegistrationGradient1Brush}" CornerRadius="10, 0, 0, 10" Margin="0, 0 -10, 0"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>

                                            <Track.Thumb>
                                                <Thumb Width="40" Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType=Slider}}" Background="White" BorderBrush="Gray" BorderThickness="1">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border CornerRadius="10">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="{DynamicResource ForRegistrationGradient1}" Offset="0"/>
                                                                        <GradientStop Color="{DynamicResource ForRegistrationGradient1}" Offset="0.2"/>
                                                                        <GradientStop Color="{DynamicResource ForRegistrationGradient2}"  Offset="1.4"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>
                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.35*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.35*"/>
                            </Grid.ColumnDefinitions>

                            <Border Name="m10" Grid.Column="1" Margin="1" Style="{StaticResource ButtonStyle}" CornerRadius="3" PreviewMouseDown="Minute_PreviewMouseDown" PreviewMouseUp="Minute_PreviewMouseUp" MouseLeave="p10_MouseLeave">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                                </Border.Effect>
                                <Viewbox Margin="4">
                                    <TextBlock Text="-10" Style="{StaticResource ButtonStyleT}"/>
                                </Viewbox>
                            </Border>

                            <Border Name="m1" Grid.Column="3" Margin="1" Style="{StaticResource ButtonStyle}" CornerRadius="3" PreviewMouseDown="Minute_PreviewMouseDown" PreviewMouseUp="Minute_PreviewMouseUp"  MouseLeave="p10_MouseLeave">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                                </Border.Effect>
                                <Viewbox Margin="4">
                                    <TextBlock Text="-1" Style="{StaticResource ButtonStyleT}"/>
                                </Viewbox>
                            </Border>

                            <Border Name="p1" Grid.Column="5" Margin="1" Style="{StaticResource ButtonStyle}" CornerRadius="3" PreviewMouseDown="Minute_PreviewMouseDown" PreviewMouseUp="Minute_PreviewMouseUp" MouseLeave="p10_MouseLeave">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                                </Border.Effect>
                                <Viewbox Margin="4">
                                    <TextBlock Text="+1" Style="{StaticResource ButtonStyleT}"/>
                                </Viewbox>
                            </Border>

                            <Border Name="p10" Grid.Column="7" Margin="1" Style="{StaticResource ButtonStyle}" CornerRadius="3" PreviewMouseDown="Minute_PreviewMouseDown" PreviewMouseUp="Minute_PreviewMouseUp" MouseLeave="p10_MouseLeave">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                                </Border.Effect>
                                <Viewbox Margin="4">
                                    <TextBlock Text="+10" Style="{StaticResource ButtonStyleT}"/>
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Border Visibility="{Binding ElementName=EndAddRouteGrid, Path=Visibility}" Background="{DynamicResource HintColor}" Grid.Row="0" CornerRadius="15" Grid.RowSpan="5" Grid.ColumnSpan="5" Opacity="0.08">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="50" Opacity="0.3" />
            </Border.Effect>
        </Border>

        <Grid Name="EndAddRouteGrid" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5.5*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource White}" Grid.Row="1" Grid.Column="1" CornerRadius="13  ">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.3*"/>
                    <RowDefinition Height="0.7*"/>
                    <RowDefinition Height="0.1*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="0.3*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.Resources>
                    <Style TargetType="Path">
                        <Setter Property="Stretch" Value="Uniform"/>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Fill" Value="{DynamicResource HintColor}"/>
                        <Setter Property="RenderTransformOrigin" Value="0.5, 0.5"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <RotateTransform Angle="180"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <Grid Grid.ColumnSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1" Grid.Row="1" Background="{DynamicResource White}" Style="{StaticResource ButtonStyle}" PreviewMouseDown="BackAddRouteEnd_PreviewMouseDown">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="1.5*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Path Grid.Row="1" Stretch="Uniform" Fill="{DynamicResource MainColor100}" Data="{DynamicResource arrow}" Margin="0">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                        </Border.Effect>
                    </Border>
                </Grid>

                <Path Grid.Row="1" Grid.Column="4" Data="{DynamicResource pensioner 1}"/>
                <Path Grid.Row="1" Grid.Column="5" Data="{DynamicResource adult 1}"/>
                <Path Grid.Row="1" Grid.Column="6" Data="{DynamicResource child 1}" Margin="7"/>
                <Path Grid.Row="1" Grid.Column="7" Data="{DynamicResource baby 1}" Margin="6"/>
                <Path Grid.Row="1" Grid.Column="8" Data="{DynamicResource suitcase}" Margin="9">
                    <Path.RenderTransform>
                        <RotateTransform Angle="0"/>
                    </Path.RenderTransform>
                </Path>

                <StackPanel Grid.Column="2" Grid.Row="3" Margin="0,10,0,0">
                    <Border Visibility="{Binding ElementName=EconomBorder, Path=Visibility}" Height="{Binding BaggagePrice}" Margin="0, 0, 0, 10" BorderBrush="{DynamicResource EconomColor}" BorderThickness="1.5" CornerRadius="4"/>
                    <Border Visibility="{Binding ElementName=BussinessBorder, Path=Visibility}" Height="{Binding BaggagePrice}" Margin="0, 0, 0, 10" BorderBrush="{DynamicResource BussinessColor}" BorderThickness="1.5" CornerRadius="4"/>
                    <Border Visibility="{Binding ElementName=FirstBorder, Path=Visibility}" Height="{Binding BaggagePrice}" Margin="0, 0, 0, 10" BorderBrush="{DynamicResource FirstColor}" BorderThickness="1.5" CornerRadius="4"/>
                </StackPanel>

                <Grid Name="ResultTableGrid" Grid.Column="4" Grid.ColumnSpan="5" Grid.Row="3">
                    <Grid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Bahnschrift"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>

                        <Style TargetType="ScrollViewer">
                            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
                            <EventSetter Event="PreviewMouseWheel" Handler="ScrollViewer_PreviewHorizontalMouseWheel"/>
                        </Style>
                    </Grid.Resources>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="{Binding BaggagePrice}"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="{Binding BaggagePrice}"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="{Binding BaggagePrice}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                </Grid>
            </Grid>
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="Bahnschrift"/>
                        <Setter Property="FontSize" Value="20"/>
                    </Style>

                    <Style TargetType="ScrollViewer">
                        <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                        <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
                        <EventSetter Event="PreviewMouseWheel" Handler="ScrollViewer_PreviewHorizontalMouseWheel"/>
                    </Style>
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3.5*"/>
                    <RowDefinition Height="1.5*"/>
                    <RowDefinition Height="0.5*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="3.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Grid.Row="1">
                    <ScrollViewer>
                        <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 5">
                            <TextBlock Text="Шлях:   "/>
                            <TextBlock Text="{Binding ElementName=AirportPicker, Path=DepartureAirport}" FontWeight="Bold"/>
                            <TextBlock Text=" - "/>
                            <TextBlock Text="{Binding ElementName=AirportPicker, Path=ArrivalAirport}" FontWeight="Bold"/>
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 5">
                        <TextBlock Text="Обраний літак:   "/>
                        <TextBlock Text="{Binding PlaneName}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Тривалість маршруту:   "/>
                        <TextBlock Text="{Binding TimeString}" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding RouteName}" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="27" Foreground="{DynamicResource MainColor100}" FontFamily="Bahnschrift"/>
            </Grid>
            
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="0.5*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource ButtonStyle}" PreviewMouseDown="AddRouteEnds_PreviewMouseDown">
                    <Viewbox Margin="8">
                        <TextBlock Text="Додати" FontFamily="Bahnschrift" Style="{StaticResource ButtonStyleT}"/>
                    </Viewbox>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                    </Border.Effect>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
