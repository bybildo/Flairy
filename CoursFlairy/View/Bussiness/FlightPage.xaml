<Page x:Class="CoursFlairy.View.Bussiness.FlightPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:convertersearch="clr-namespace:CoursFlairy.ViewModel.Converter.SearchPage"
      xmlns:local="clr-namespace:CoursFlairy.View.Bussiness"
      mc:Ignorable="d" Loaded="Page_Loaded"
      d:DesignHeight="650" d:DesignWidth="1040"
      Title="FlightPage">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="ButtonStyle">
            <Setter Property="Background" Value="{DynamicResource White}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)" To="0.6"/>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)" To="5"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>

                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)" To="0.35"/>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)" To="4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="ButtonStyleT">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
            <Setter Property="Foreground" Value="{DynamicResource MainColor100}"/>
        </Style>

        <convertersearch:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" StrokeDashArray="1 2" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="true" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListBoxItemContainerStyle1" TargetType="{x:Type ListBoxItem}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"/>
            <Setter Property="VerticalContentAlignment" Value="{Binding VerticalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Grid Height="{Binding ListItemHeight, RelativeSource={RelativeSource AncestorType={x:Type Page}}}" Margin="2, 1, 2, 30">
                            <Border x:Name="Bd" CornerRadius="10" Background="{DynamicResource White}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="ShadowEffect" BlurRadius="3" ShadowDepth="0.2" Color="{DynamicResource Shadow}" Direction="270" Opacity="0.3" />
                                </Border.Effect>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="26*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="0.6*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="1.3*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <ScrollViewer MouseEnter="ScrollViewer_MouseEnter" MouseLeave="ScrollViewer_MouseLeave" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                                        <TextBlock Text="{Binding RouteName}" VerticalAlignment="Center" FontFamily="Bahnschrift" Foreground="{DynamicResource MainColor100}" FontSize="24"/>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="UIElement.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect" 
                   Storyboard.TargetProperty="Opacity" 
                   From="0.3" To="0.6" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect" 
                   Storyboard.TargetProperty="BlurRadius" 
                   From="3" To="5" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="UIElement.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect" 
                   Storyboard.TargetProperty="Opacity" 
                   From="0.6" To="0.3" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect" 
                   Storyboard.TargetProperty="BlurRadius" 
                   From="5" To="3" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="MainGrid" Background="White" DataContext="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=Page, Mode=FindAncestor}}">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.1*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="0.05*"/>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="0.1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border BorderBrush="{DynamicResource MainColor20}" Background="Transparent" BorderThickness="1" Grid.Column="1" Grid.Row="1" CornerRadius="6">
                <Grid Margin="5, 0, 5, 0">
                    <TextBlock Text="Пошук за назвою рейсу" Grid.Column="1" FontSize="20" Margin="2,0,0,0" Foreground="{DynamicResource HintColor}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=FlightSearch, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                    <ScrollViewer  Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                        <TextBox Name="FlightSearch" Foreground="{DynamicResource Black}" Text="{Binding FlightName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="200" FontFamily="Bahnschrift" FontSize="25"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="5" Grid.Row="1" Style="{StaticResource ButtonStyle}" MouseDown="AddFlight_MouseDown">
                <Viewbox Margin="9">
                    <TextBlock Text="Додати рейс" FontFamily="Bahnschrift" Style="{StaticResource ButtonStyleT}"/>
                </Viewbox>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>
            <Path Grid.Column="3" Grid.Row="1" Stretch="Uniform" Fill="{DynamicResource MainColor100}" Data="{DynamicResource filter}" Margin="0,7,0,7"/>
        </Grid>
        <Line Stroke="Navy" StrokeThickness="1" VerticalAlignment="Bottom" X2="{Binding ElementName=MainGrid, Path=ActualWidth}"/>

        <Grid Grid.Row="3" Name="FlightGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="0.35*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Column="1" Grid.Row="1">
                <Border Margin="5" Height="{Binding AddItemHeight}" VerticalAlignment="Top" CornerRadius="8" Background="{DynamicResource White}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                    </Border.Effect>
                </Border>

                <Grid Height="{Binding AddItemHeight}" Margin="5" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="8*"/>
                        <ColumnDefinition Width="0*"/>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.4*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="0.1*"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="0.5*"/>
                    </Grid.RowDefinitions>

                    <Viewbox Grid.Column="1" Grid.Row="1">
                        <TextBlock Style="{StaticResource ButtonStyleT}" Text="Маршрут" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Viewbox>
                    <Border Name="PlaneBorder" Grid.Row="3" Grid.Column="1" CornerRadius="10" BorderThickness="1.8" BorderBrush="{DynamicResource MainColor20}"/>
                    <Grid Grid.Row="3" Grid.Column="1">
                        <Grid Margin="10, 0, 10, 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="7*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Введіть назву маршруту" FontSize="17" Margin="2,0,0,0"  Foreground="{DynamicResource HintColor}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=routenametb, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                            <ScrollViewer Margin="0,0,0,-2" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                                <Grid>
                                    <TextBlock Text="{Binding RouteHint,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource HintColor}" FontSize="20" FontFamily="Bahnschrift" Opacity="0.6" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    <TextBox Name="routenametb" PreviewKeyDown="KeyControl" Text="{Binding RouteName,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="20" Foreground="{DynamicResource Black}" FontFamily="Bahnschrift" MaxLength="100" TextChanged="ColorUpdate_TextChanged"/>
                                </Grid>
                            </ScrollViewer>

                            <Path x:Name="RouteButton" Visibility="Hidden" Grid.Column="2" Data="{DynamicResource tabButton}" Fill="{DynamicResource MainColor100}" Stretch="Uniform" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <Viewbox Grid.Column="3" Grid.Row="1">
                        <TextBlock Style="{StaticResource ButtonStyleT}" Text="Дата" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Viewbox>

                    <Grid Grid.Column="3" Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.1*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.1*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                                <Setter Property="Grid.Row" Value="1"/>
                                <Setter Property="BorderThickness" Value="1.8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource MainColor20}"/>
                            </Style>
                        </Grid.Resources>

                        <Border Name="DayBorder" Grid.Column="1"/>
                        <TextBlock Grid.Column="1" Grid.Row="1" Visibility="{Binding ElementName=DayTb, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}" FontSize="20 " HorizontalAlignment="Center" VerticalAlignment="Center" Text="dd" Foreground="{DynamicResource HintColor}" Opacity="0.75"/>
                        <TextBox Name="DayTb" Grid.Column="1" Grid.Row="1" FontSize="20" HorizontalAlignment="Center" MaxLength="2" PreviewTextInput="DayTb_PreviewTextInput" PreviewKeyDown="KeyControl" TextChanged="ColorUpdate_TextChanged"/>
                        <Grid Name="DayGrid" Grid.Column="1" Grid.Row="1" Background="Transparent" MouseDown="DateGrid_MouseDown"/>

                        <TextBlock Text="." Grid.Column="2" Grid.Row="1" FontSize="20" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>

                        <Border Name="MonthBorder" Grid.Column="3"/>
                        <TextBlock Grid.Column="3" Grid.Row="1" Visibility="{Binding ElementName=MonthTb, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Text="mm" Foreground="{DynamicResource HintColor}" Opacity="0.75"/>
                        <TextBox Name="MonthTb" Grid.Column="3" Grid.Row="1" FontSize="20" HorizontalAlignment="Center" MaxLength="2" PreviewTextInput="MonthTb_PreviewTextInput" PreviewKeyDown="KeyControl" TextChanged="ColorUpdate_TextChanged"/>
                        <Grid Name="MonthGrid" Grid.Column="3" Grid.Row="1" Background="Transparent" MouseDown="DateGrid_MouseDown"/>

                        <TextBlock Text="." Grid.Column="4" Grid.Row="1" FontSize="20" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>

                        <TextBlock Name="YearTb" Grid.Column="5" Grid.Row="1" Text="2025" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource MainColor100}" Opacity="0.75"/>
                    </Grid>

                    <Viewbox Grid.Column="5" Grid.Row="1">
                        <TextBlock Style="{StaticResource ButtonStyleT}" Text="Час" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Viewbox>

                    <Grid Grid.Column="5" Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="0.5*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                                <Setter Property="Grid.Row" Value="1"/>
                                <Setter Property="BorderThickness" Value="1.8"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource MainColor20}"/>
                            </Style>
                        </Grid.Resources>

                        <Border Name="HourBorder" Grid.Column="1"/>
                        <TextBlock Grid.Column="1" Grid.Row="1" Visibility="{Binding ElementName=HourTb, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}" FontSize="20 " HorizontalAlignment="Center" VerticalAlignment="Center" Text="hh" Foreground="{DynamicResource HintColor}" Opacity="0.75"/>
                        <TextBox Name="HourTb" Grid.Column="1" Grid.Row="1" FontSize="20" HorizontalAlignment="Center" MaxLength="2" PreviewTextInput="HourTb_PreviewTextInput" PreviewKeyDown="KeyControl" TextChanged="ColorUpdate_TextChanged"/>
                        <Grid Name="HourGrid" Grid.Column="1" Grid.Row="1" Background="Transparent" MouseDown="DateGrid_MouseDown"/>

                        <TextBlock Text=":" Grid.Column="2" Grid.Row="1" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0"/>

                        <Border Name="MinuteBorder" Grid.Column="3"/>
                        <TextBlock Grid.Column="3" Grid.Row="1" Visibility="{Binding ElementName=MinuteTb, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Text="mm" Foreground="{DynamicResource HintColor}" Opacity="0.75"/>
                        <TextBox Name="MinuteTb" Grid.Column="3" Grid.Row="1" FontSize="20" HorizontalAlignment="Center" MaxLength="2" PreviewTextInput="MinuteTb_PreviewTextInput" PreviewKeyDown="KeyControl" TextChanged="ColorUpdate_TextChanged"/>
                        <Grid Name="MinuteGrid" Grid.Column="3" Grid.Row="1" Background="Transparent" MouseDown="DateGrid_MouseDown"/>
                    </Grid>

                    <Path Name="AddButton" Grid.Column="7" Grid.RowSpan="5" Fill="{DynamicResource MainColor20}" Data="{DynamicResource square}" Stretch="Uniform"/>
                    <TextBlock Grid.Column="7" Grid.RowSpan="5" Text="+" FontFamily="Bahnschrift" FontSize="30" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource White}" Margin="0,0,0,-2"/>
                    <Grid Grid.Column="7" Grid.RowSpan="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="1.4*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="1" Name="AddActiveGrid" Background="Transparent" MouseDown="AddButtonNotActive_MouseDown"/>
                    </Grid>
                </Grid>
            </Grid>

            <ScrollViewer Grid.Row="2" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <ListBox ItemContainerStyle="{DynamicResource ListBoxItemContainerStyle1}" ItemsSource="{Binding Flights}" Background="Transparent" BorderBrush="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">

                </ListBox>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
