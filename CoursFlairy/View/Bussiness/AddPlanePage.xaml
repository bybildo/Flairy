<Page x:Class="CoursFlairy.View.Bussiness.AddPlanePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoursFlairy.View.Bussiness"
      xmlns:convertersearch="clr-namespace:CoursFlairy.ViewModel.Converter.SearchPage"
      xmlns:converter="clr-namespace:CoursFlairy.ViewModel.Converter.Bussines"
      mc:Ignorable="d" Loaded="Page_Loaded" KeyDown="Page_KeyDown"
      d:DesignHeight="650" d:DesignWidth="1040"
      Title="AddPlanePage">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="ButtonStyle">
            <Setter Property="Background" Value="{DynamicResource White}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)" To="0.6"/>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)" To="5"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>

                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)" To="0.35"/>
                                <DoubleAnimation Duration="0:0:0.25" Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)" To="4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="ButtonStyleT">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
            <Setter Property="Foreground" Value="{DynamicResource MainColor100}"/>
        </Style>

        <convertersearch:TextToVisibilityConverter x:Key="TextToVisibilityConverter"/>
        <converter:PlaneBackHeightConverter x:Key="PlaneBackHeightConverter"/>
        <converter:PlaneWindHeightConverter x:Key="PlaneWindHeightConverter"/>
        <converter:ToogleButtonColorConvertor x:Key="ToogleButtonColorConvertor"/>
        <converter:BoolToVisiblityConverter x:Key="BoolToVisiblityConverter"/>
        <converter:TextToColorNullConverter x:Key="TextToColorNullConverter"/>

        <Style x:Key="ScrollBarThumbVertical" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Rectangle Margin="5, 0, -5,0 " x:Name="rectangle" Fill="{DynamicResource MainColor100}" RadiusX="4" RadiusY="4" Opacity="0.9" SnapsToDevicePixels="True" Width="{TemplateBinding Width}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumbHorizontal" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Rectangle Margin="0, 5, 0,-5 " x:Name="rectangle" Fill="{DynamicResource MainColor100}" RadiusX="4" RadiusY="4" Opacity="0.9" Height="{TemplateBinding Height}" SnapsToDevicePixels="True" Width="{TemplateBinding Width}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RepeatButtonTransparent" TargetType="{x:Type RepeatButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1,0"/>
            <Setter Property="Width" Value="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}"/>
            <Setter Property="MinWidth" Value="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.02*"/>
                                <RowDefinition Height="4*"/>
                                <RowDefinition Height="0.02*"/>
                            </Grid.RowDefinitions>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Grid.Row="1"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsMouseOver}" Grid.Row="1">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbVertical}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="Height" Value="{DynamicResource {x:Static SystemParameters.HorizontalScrollBarHeightKey}}"/>
                    <Setter Property="MinHeight" Value="{DynamicResource {x:Static SystemParameters.HorizontalScrollBarHeightKey}}"/>
                    <Setter Property="BorderThickness" Value="0,1"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.02*"/>
                                        <ColumnDefinition Width="4*"/>
                                        <ColumnDefinition Width="0.02*"/>
                                    </Grid.ColumnDefinitions>
                                    <Track x:Name="PART_Track" Grid.Column="1" IsEnabled="{TemplateBinding IsMouseOver}">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbHorizontal}"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanHorizontallyScroll="False" ContentTemplate="{TemplateBinding ContentTemplate}" CanVerticallyScroll="False" Grid.Column="0" Content="{TemplateBinding Content}" CanContentScroll="{TemplateBinding CanContentScroll}" Margin="{TemplateBinding Padding}" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" AutomationProperties.AutomationId="VerticalScrollBar" Cursor="Arrow" Grid.Column="1" Maximum="{TemplateBinding ScrollableHeight}" Minimum="0" Grid.Row="0" Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource Mode=TemplatedParent}}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar" AutomationProperties.AutomationId="HorizontalScrollBar" Cursor="Arrow" Grid.Column="0" Maximum="{TemplateBinding ScrollableWidth}" Minimum="0" Orientation="Horizontal" Grid.Row="1" Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource Mode=TemplatedParent}}" ViewportSize="{TemplateBinding ViewportWidth}" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="false">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid x:Name="MainGrid" Background="White" DataContext="{Binding RelativeSource={RelativeSource AncestorLevel=1, AncestorType=Page, Mode=FindAncestor}}">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="8.5*"/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="1.25*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>

        <!--Верхнє меню-->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.05*"/>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="0.15*"/>
                <ColumnDefinition Width="0.25*"/>
                <ColumnDefinition Width="0.05*"/>
                <ColumnDefinition Width="0.25*"/>
                <ColumnDefinition Width="0.15*"/>
                <ColumnDefinition Width="0.22*"/>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="0.05*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource ButtonStyle}" PreviewMouseDown="BackAddPlane_PreviewMouseDown">
                <Viewbox Margin="8">
                    <TextBlock Text="Назад" FontFamily="Bahnschrift" Style="{StaticResource ButtonStyleT}"/>
                </Viewbox>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>

            <Border BorderBrush="{DynamicResource MainColor20}" Background="Transparent" BorderThickness="1" Grid.Column="3" Grid.Row="1" CornerRadius="6">
                <Grid Margin="5, 0, 5, 0">
                    <TextBlock Text="Модель літака" Grid.Column="1" FontSize="20" Margin="2,0,0,0" Foreground="{DynamicResource HintColor}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=PlaneName, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                    <ScrollViewer  Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                        <TextBox Name="PlaneName" Foreground="{DynamicResource Black}" Text="{Binding PlaneNameTb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="255" FontFamily="Bahnschrift" FontSize="25"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border BorderBrush="{DynamicResource MainColor20}" Background="Transparent" BorderThickness="1" Grid.Column="5" Grid.Row="1" CornerRadius="6">
                <Grid Margin="5, 0, 5, 0">
                    <TextBlock Text="↔" Grid.Column="1" FontSize="20" Margin="1,0,0,0" Foreground="{DynamicResource HintColor}" HorizontalAlignment="Center" FontFamily="{DynamicResource BlackerSans Pro It Variable}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=Width, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                    <ScrollViewer HorizontalAlignment="Center" Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                        <TextBox Name="Width" Text="{Binding WidthTb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource Black}" MaxLength="3" FontFamily="Bahnschrift" FontSize="25" PreviewTextInput="SizeInput"/>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Grid Grid.Column="5" Grid.Row="1" Background="Transparent" Cursor="IBeam" PreviewMouseDown="ToWidth_PreviewMouseDown"/>

            <Border BorderBrush="{DynamicResource MainColor20}" Background="Transparent" BorderThickness="1" Grid.Column="7" Grid.Row="1" CornerRadius="6">
                <Grid Margin="5, 0, 5, 0">
                    <TextBlock Text="↕" Grid.Column="1" FontSize="20" Margin="0,0,0,0" Foreground="{DynamicResource HintColor}" HorizontalAlignment="Center" FontFamily="{DynamicResource BlackerSans Pro It Variable}" Opacity="0.6" VerticalAlignment="Center" Visibility="{Binding ElementName=Height, Path=Text, Mode=OneWay, Converter={StaticResource TextToVisibilityConverter}}"/>
                    <ScrollViewer HorizontalAlignment="Center" Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden" PanningMode="HorizontalOnly" PreviewMouseWheel="ScrollViewer_PreviewHorizontalMouseWheel">
                        <TextBox Name="Height" Text="{Binding HeightTb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource Black}" MaxLength="2" FontFamily="Bahnschrift" FontSize="25" PreviewTextInput="SizeInput"/>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Grid Grid.Column="7" Grid.Row="1" Background="Transparent" Cursor="IBeam" PreviewMouseDown="ToHeight_PreviewMouseDown"/>


            <Border Grid.Column="9" Grid.Row="1" Style="{StaticResource ButtonStyle}" MouseDown="UpdatePlane_MouseDown">
                <Path Margin="10" Fill="Transparent" Stroke="{DynamicResource MainColor100}" StrokeThickness="1" Stretch="Uniform" Data="{Binding ButtonGeometry}"/>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>

            <Border Visibility="{Binding SeatsHave, Converter={StaticResource BoolToVisiblityConverter}}" MouseDown="AddPlane_MouseDown" Grid.Column="11" Grid.Row="1" Style="{StaticResource ButtonStyle}">
                <Viewbox Margin="8">
                    <TextBlock Text="Додати" FontFamily="Bahnschrift" Style="{StaticResource ButtonStyleT}"/>
                </Viewbox>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>
        </Grid>
        <Line Stroke="Navy" StrokeThickness="1" VerticalAlignment="Bottom" X2="{Binding ElementName=MainGrid, Path=ActualWidth}"/>

        <!--Нижнє меню-->
        <Grid Grid.Row="3">
            <Grid.Resources>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="60"/>
                    <Setter Property="BorderThickness" Value="2.3"/>
                    <Setter Property="BorderBrush" Value="Navy"/>
                    <Setter Property="Background" Value="{DynamicResource White}"/>
                    <Setter Property="Margin" Value="5, 0, 5, 0"/>
                    <Setter Property="CornerRadius" Value="6"/>
                    <Setter Property="UseLayoutRounding" Value="True"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <EventSetter Event="MouseDown" Handler="ChangeBrush"/>
                </Style>
            </Grid.Resources>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border x:Name="EmptyBorder" BorderBrush="{DynamicResource EmptyButtonColor}" Background="{DynamicResource EmptyButtonColor}">
                    <Viewbox Margin="10">
                        <TextBlock Text="Пусто" FontFamily="Bahnschrift" Foreground="{DynamicResource White}"/>
                    </Viewbox>
                </Border>

                <Border Name="EnterBorder" BorderBrush="{DynamicResource EnterColor}">
                    <Path Stretch="Uniform" StrokeThickness="2" Stroke="{DynamicResource EnterColor}" Data="{DynamicResource enter}" Margin="10,0,12,0"/>
                </Border>

                <Border x:Name="WCBorder" BorderBrush="{DynamicResource WCColor}" Margin="5,0,12,0">
                    <Viewbox Margin="12">
                        <TextBlock Text="WC" FontFamily="Bahnschrift" Foreground="{DynamicResource WCColor}"/>
                    </Viewbox>
                </Border>

                <Border x:Name="EconomBorder" Margin="12,0,5,0" BorderBrush="{DynamicResource EconomColor}">
                    <Path Stretch="Uniform" StrokeThickness="1" Stroke="{DynamicResource EconomColor}" Data="{DynamicResource adult 1}" RenderTransformOrigin="0.5,0.5" Margin="10">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="180"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Border>

                <Border x:Name="BussinessBorder" BorderBrush="{DynamicResource BussinessColor}">
                    <Path Stretch="Uniform" StrokeThickness="1" Stroke="{DynamicResource BussinessColor}" Data="{DynamicResource adult 2}" RenderTransformOrigin="0.5,0.5" Margin="10">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="180"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Border>

                <Border x:Name="FirstBorder" BorderBrush="{DynamicResource FirstColor}">
                    <Path Stretch="Uniform" StrokeThickness="1" Stroke="{DynamicResource FirstColor}" Data="{DynamicResource adult 3}" RenderTransformOrigin="0.5,0.5" Margin="10">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="180"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Border>
            </StackPanel>
        </Grid>

        <!--Створення-->
        <Grid Grid.Row="1" Name="ConstructorGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="11*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <Style TargetType="Path">
                    <Setter Property="Visibility" Value="{Binding ShowPlane, Converter={StaticResource BoolToVisiblityConverter}}"/>
                </Style>
            </Grid.Resources>

            <!-- Основне ItemsControl, яке прив'язується до PlaneStructsList -->
            <ScrollViewer Name="ConstructorScroll" Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Path Name="planeHead" Margin="0,0,-1,0" Fill="{DynamicResource EmptyColor}" Stretch="Uniform" Data="{DynamicResource plane head}" Height="{Binding ElementName=Constructor, Path=ActualHeight}" HorizontalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <Grid VerticalAlignment="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="0.8*" />
                            </Grid.ColumnDefinitions>

                            <Path Name="planeWingTop" Margin="0,0,0,-2" Fill="{DynamicResource EmptyColor}" VerticalAlignment="Bottom" Stretch="Uniform" RenderTransformOrigin="0.5, 0.5" Data="{DynamicResource plane wing}" HorizontalAlignment="Center" Height="{Binding ElementName=Constructor, Path=ActualHeight, Converter={StaticResource PlaneWindHeightConverter}}">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleY="-1"/>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <Line Stroke="Transparent" StrokeThickness="2" X2="{Binding ForLine1}"/>
                            <Line Stroke="{DynamicResource MainColor100}" StrokeThickness="2" X2="{Binding ForLine2}"/>
                        </StackPanel>
                        <Grid Background="{DynamicResource EmptyColor}">
                            <ItemsControl Name="Constructor" Background="{DynamicResource EmptyColor}" Width="{Binding ConstructorWidthItem}" HorizontalAlignment="Center" ItemsSource="{Binding PlaneStructsList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="{Binding DataContext.ConstructorColumns, RelativeSource={RelativeSource AncestorType=Page}}" Width="{Binding DataContext.ConstructorWidth, RelativeSource={RelativeSource AncestorType=Page}}"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Width="{Binding Width}" Height="{Binding Height}" >
                                                        <Grid Background="Transparent" PreviewMouseDown="Grid_MouseDown" PreviewMouseUp="Grid_MouseUp" PreviewMouseMove="Grid_MouseMove" MouseEnter="ConstructorHint_MouseEnter" MouseLeave="ConstructorHint_MouseLeave">
                                                            <Grid.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderBrush" Value="{Binding BorderBrush}"/>
                                                                    <Setter Property="Background" Value="{Binding Background}"/>
                                                                    <Setter Property="CornerRadius" Value="{Binding Radius}"/>
                                                                    <Setter Property="Margin" Value="{Binding Margin}"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                    <Setter Property="UseLayoutRounding" Value="True"/>
                                                                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                                                </Style>

                                                                <Style TargetType="Path">
                                                                    <Setter Property="Stretch" Value="Uniform"/>
                                                                    <Setter Property="Fill" Value="{Binding SvgColor}"/>
                                                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                                    <Setter Property="Margin" Value="-5"/>
                                                                </Style>
                                                            </Grid.Resources>
                                                            <Border>
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>

                                                                    <Path Grid.Row="1" Data="{DynamicResource arrow}" RenderTransform="{Binding PathAngleTransform}"/>
                                                                    <Path Grid.Row="2" Data="{DynamicResource arrow}" RenderTransform="{Binding PathAngleTransform}"/>
                                                                </Grid>
                                                            </Border>
                                                            <Border Background="{DynamicResource Black}" BorderBrush="{DynamicResource Black}" Opacity="{Binding HintOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </Grid>
                                                        <Grid Background="{Binding TextBoxText, Converter={StaticResource TextToColorNullConverter}}" PreviewMouseRightButtonDown="TextBox_PreviewMouseRightButtonDown" MouseEnter="TextBox_MouseEnter" MouseLeave="TextBox_MouseLeave">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition Height="2.5*"/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>

                                                            <Viewbox Grid.Row="1" HorizontalAlignment="Center">
                                                                <TextBox Text="{Binding TextBoxText}" Visibility="{Binding TextBoxVisibility}" FontFamily="Bahnschrift" Foreground="{DynamicResource MainColor100}" MaxLength="1" ContextMenu="{x:Null}" Loaded="TextBox_Loaded" PreviewTextInput="TextBox_PreviewTextInput" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                                                            </Viewbox>
                                                        </Grid>
                                                        <Grid Background="{Binding TextBoxSeatText, Converter={StaticResource TextToColorNullConverter}}" Margin="{Binding DataContext.TextBoxSeatMargin, RelativeSource={RelativeSource AncestorType=Page}}" PreviewMouseRightButtonDown="TextBoxSeat_PreviewMouseRightButtonDown" MouseEnter="TextBoxSeat_MouseEnter" MouseLeave="TextBoxSeat_MouseLeave" >
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition Height="3*"/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>

                                                            <Viewbox Grid.Row="1" HorizontalAlignment="Center">
                                                                <TextBox Panel.ZIndex="3" Text="{Binding TextBoxSeatText}" Visibility="{Binding TextBoxSeatVisibility}" FontFamily="Bahnschrift" Foreground="{DynamicResource MainColor100}" MaxLength="3" ContextMenu="{x:Null}" Loaded="TextBox_Loaded" PreviewTextInput="SizeInput" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                                                            </Viewbox>
                                                        </Grid>

                                                        <Grid Margin="{Binding DataContext.TextBoxSeatMargin, RelativeSource={RelativeSource AncestorType=Page}}">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition Height="2*"/>
                                                                <RowDefinition/>
                                                            </Grid.RowDefinitions>

                                                            <Viewbox Grid.Row="1" HorizontalAlignment="Center">
                                                                <TextBlock Panel.ZIndex="3" Text="{Binding TextBlockStateText}" Visibility="{Binding TextBlockStateVisiblity}" FontFamily="Bahnschrift" Foreground="{DynamicResource MainColor100}" MouseDown="TextBlock_MouseDown"/>
                                                            </Viewbox>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Panel.ZIndex="1">
                            <Line Stroke="Transparent" StrokeThickness="2" X2="{Binding ForLine1}"/>
                            <Line Stroke="{DynamicResource MainColor100}" StrokeThickness="2" X2="{Binding ForLine2}"/>
                        </StackPanel>
                        <Grid VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="0.8*" />
                            </Grid.ColumnDefinitions>

                            <Path Name="planeWingBottom" Margin="0,-2,0,0" Fill="{DynamicResource EmptyColor}" Stretch="Uniform" Data="{DynamicResource plane wing}" Height="{Binding ElementName=Constructor, Path=ActualHeight, Converter={StaticResource PlaneWindHeightConverter}}" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                    <Path Name="planeBack" Margin="-1,0,0,0" Fill="{DynamicResource EmptyColor}" Stretch="Fill" Width="{Binding ElementName=planeWingBottom, Path=ActualWidth}" Data="{DynamicResource plane back}" Height="{Binding ElementName=Constructor, Path=ActualHeight, Converter={StaticResource PlaneBackHeightConverter}}" VerticalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Name="ToogleButtonGrid" Grid.Row="1" Grid.Column="1">
                    <Line HorizontalAlignment="Center" Y2="{Binding ElementName=ToogleButtonGrid, Path=ActualHeight}" Stroke="{DynamicResource HintColor}" StrokeThickness="4" Opacity="0.5"/>

                    <Grid Background="Transparent" MouseDown="ToogleButton_MouseDown">
                        <Grid.RowDefinitions>
                            <RowDefinition Name="ToogleButtonRow1" Height="{Binding ToogleButtonRow1Height}"/>
                            <RowDefinition Height="0.5*"/>
                            <RowDefinition Name="ToogleButtonRow2" Height="{Binding ToogleButtonRow2Height}"/>
                        </Grid.RowDefinitions>

                        <Rectangle Grid.Row="1" RadiusX="3" RadiusY="3">
                            <Rectangle.Fill>
                                <MultiBinding Converter="{StaticResource ToogleButtonColorConvertor}">
                                    <Binding Path="ToogleButtonRow1Height" />
                                    <Binding Path="ToogleButtonRow2Height" />
                                </MultiBinding>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        <Border Visibility="{Binding ElementName=EndAddPlaneGrid, Path=Visibility}" Background="{DynamicResource HintColor}" Grid.Row="0" CornerRadius="15" Grid.RowSpan="5" Grid.ColumnSpan="5" Opacity="0.08">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="50" Opacity="0.3" />
            </Border.Effect>
        </Border>
        <Grid Name="EndAddPlaneGrid" Grid.Row="1" Grid.Column="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5.5*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="{DynamicResource White}" Grid.Row="1" Grid.Column="1" CornerRadius="13  ">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                </Border.Effect>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="0.55*"/>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="2.8*"/>
                    <RowDefinition Height="0.4*"/>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="0.3*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="1" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.0*"/>
                        <ColumnDefinition Width="0.18*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="0.38*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="1" Background="{DynamicResource White}" Style="{StaticResource ButtonStyle}" PreviewMouseDown="BackAddPlaneEnd_PreviewMouseDown">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Path Grid.Row="1" Stretch="Uniform" Fill="{DynamicResource MainColor100}" Data="{DynamicResource arrow}"/>
                        </Grid>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                        </Border.Effect>
                    </Border>

                    <Viewbox Grid.Column="3" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding PlaneNameTb}" FontFamily="Bahnschrift" Foreground="{StaticResource MainColor100}"/>
                    </Viewbox>
                </Grid>

                <Viewbox Grid.Column="1" Grid.Row="3">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Margin="0,0,-1,0" Fill="{DynamicResource EmptyColor}" Stretch="Uniform" Data="{DynamicResource plane head}" Height="{Binding ElementName=Constructor2, Path=ActualHeight}" HorizontalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <Grid VerticalAlignment="Bottom">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="0.8*" />
                                </Grid.ColumnDefinitions>

                                <Path Margin="0,0,0,0" Fill="{DynamicResource EmptyColor}" VerticalAlignment="Bottom" Stretch="Uniform" RenderTransformOrigin="0.5, 0.5" Data="{DynamicResource plane wing}" HorizontalAlignment="Center" Height="{Binding ElementName=Constructor2, Path=ActualHeight, Converter={StaticResource PlaneWindHeightConverter}}">
                                    <Path.RenderTransform>
                                        <ScaleTransform ScaleY="-1"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                            <Grid Background="{DynamicResource EmptyColor}">
                                <ItemsControl Name="Constructor2" Background="{DynamicResource EmptyColor}" Width="{Binding ConstructorWidthItem}" HorizontalAlignment="Center" ItemsSource="{Binding PlaneStructsListEnd}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ItemsControl ItemsSource="{Binding}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="{Binding DataContext.ConstructorColumns, RelativeSource={RelativeSource AncestorType=Page}}" Width="{Binding DataContext.ConstructorWidth, RelativeSource={RelativeSource AncestorType=Page}}"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="{Binding Width}" Height="{Binding Height}" >
                                                            <Grid Background="Transparent">
                                                                <Grid.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="BorderBrush" Value="{Binding BorderBrush}"/>
                                                                        <Setter Property="Background" Value="{Binding Background}"/>
                                                                        <Setter Property="CornerRadius" Value="{Binding Radius}"/>
                                                                        <Setter Property="Margin" Value="{Binding Margin}"/>
                                                                        <Setter Property="BorderThickness" Value="2"/>
                                                                        <Setter Property="UseLayoutRounding" Value="True"/>
                                                                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                                                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                                                                    </Style>

                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Stretch" Value="Uniform"/>
                                                                        <Setter Property="Fill" Value="{Binding SvgColor}"/>
                                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                                        <Setter Property="Margin" Value="-5"/>
                                                                    </Style>
                                                                </Grid.Resources>
                                                                <Border>
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="*"/>
                                                                            <RowDefinition Height="*"/>
                                                                            <RowDefinition Height="*"/>
                                                                            <RowDefinition Height="*"/>
                                                                        </Grid.RowDefinitions>

                                                                        <Path Grid.Row="1" Data="{DynamicResource arrow}" RenderTransform="{Binding PathAngleTransform}"/>
                                                                        <Path Grid.Row="2" Data="{DynamicResource arrow}" RenderTransform="{Binding PathAngleTransform}"/>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            <Grid VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="0.8*" />
                                </Grid.ColumnDefinitions>

                                <Path Margin="0,0,0,0" Fill="{DynamicResource EmptyColor}" Stretch="Uniform" Data="{DynamicResource plane wing}" Height="{Binding ElementName=Constructor2, Path=ActualHeight, Converter={StaticResource PlaneWindHeightConverter}}" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        <Path Margin="-1,0,0,0" Fill="{DynamicResource EmptyColor}" Stretch="Fill" Width="{Binding ElementName=planeWingBottom, Path=ActualWidth}" Data="{DynamicResource plane back}" Height="{Binding ElementName=Constructor2, Path=ActualHeight, Converter={StaticResource PlaneBackHeightConverter}}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Viewbox>
                <Grid Grid.Column="1" Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1" Background="{DynamicResource MainColor100}" Style="{StaticResource ButtonStyle}" MouseDown="AddPlaneEnd_MouseDown">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="6*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Viewbox Grid.Row="1">
                                <TextBlock Text="Додати" Foreground="White" FontFamily="Bahnschrift"/>
                            </Viewbox>
                        </Grid>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="0.5" Color="{DynamicResource Shadow}" Direction="320" Opacity="0.3" />
                        </Border.Effect>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
