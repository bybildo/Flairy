<UserControl x:Class="CoursFlairy.View.UI.TicketUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoursFlairy.View.UI"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="1600">
    
    <UserControl.Resources>
        <Style x:Key="TicketTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        
        <Style x:Key="TicketHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource TicketTextStyle}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <Style x:Key="TicketValueStyle" TargetType="TextBlock" BasedOn="{StaticResource TicketTextStyle}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>
        
        <Style x:Key="TicketLargeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource TicketTextStyle}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
    </UserControl.Resources>
    
    <Border Background="White" 
            CornerRadius="12" 
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" 
                              Direction="270" 
                              ShadowDepth="4" 
                              BlurRadius="8" 
                              Opacity="0.1"/>
        </Border.Effect>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Ліва частина квитка -->
            <Border Grid.Column="0" 
                    CornerRadius="12,0,0,12"
                    Padding="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A90E2" Offset="0"/>
                        <GradientStop Color="#357ABD" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Заголовок -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Path Data="{DynamicResource plane}" 
                              Fill="White" 
                              Width="20" 
                              Height="20" 
                              Stretch="Uniform"
                              Margin="0,0,8,0"/>
                        <TextBlock Text="BOARDING PASS" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   FontSize="16"/>
                    </StackPanel>
                    
                    <!-- Маршрут -->
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Міста -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DepartureIcao}" 
                                           Foreground="White" 
                                           FontWeight="Bold" 
                                           FontSize="24" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DepartureCity}" 
                                           Foreground="#E6F3FF" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <Path Grid.Column="1" 
                                  Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" 
                                  Fill="White" 
                                  Width="24" 
                                  Height="24" 
                                  Margin="15,0"/>
                            
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ArrivalIcao}" 
                                           Foreground="White" 
                                           FontWeight="Bold" 
                                           FontSize="24" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ArrivalCity}" 
                                           Foreground="#E6F3FF" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Час -->
                        <Grid Grid.Row="1" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="DEPARTURE" 
                                           Foreground="#E6F3FF" 
                                           FontSize="10" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DepartureTimeString}" 
                                           Foreground="White" 
                                           FontWeight="Bold" 
                                           FontSize="16" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DepartureDateString}" 
                                           Foreground="#E6F3FF" 
                                           FontSize="10" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="ARRIVAL" 
                                           Foreground="#E6F3FF" 
                                           FontSize="10" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ArrivalTimeString}" 
                                           Foreground="White" 
                                           FontWeight="Bold" 
                                           FontSize="16" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ArrivalDateString}" 
                                           Foreground="#E6F3FF" 
                                           FontSize="10" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    
                    <!-- Пасажир -->
                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <TextBlock Text="PASSENGER" 
                                   Foreground="#E6F3FF" 
                                   FontSize="10" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FullName}" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   HorizontalAlignment="Center" 
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    
                    <!-- Номер рейсу -->
                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                        <TextBlock Text="FLIGHT" 
                                   Foreground="#E6F3FF" 
                                   FontSize="10" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FlightNumber}" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Перфорація -->
            <Border Grid.Column="1" Width="2" Background="#E0E0E0">
                <Canvas>
                    <Ellipse Canvas.Top="10" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="25" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="40" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="55" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="70" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="85" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="100" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="115" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="130" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="145" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                    <Ellipse Canvas.Top="160" Canvas.Left="-4" Width="8" Height="8" Fill="White"/>
                </Canvas>
            </Border>
            
            <!-- Права частина квитка -->
            <Border Grid.Column="2" 
                    Background="White" 
                    CornerRadius="0,12,12,0"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Заголовок -->
                    <TextBlock Grid.Row="0" 
                               Text="BOARDING PASS" 
                               Style="{StaticResource TicketHeaderStyle}" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,15"/>
                    
                    <!-- Деталі квитка -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Пасажир -->
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                            <TextBlock Text="Name of passenger:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding FullName}" Style="{StaticResource TicketHeaderStyle}"/>
                        </StackPanel>
                        
                        <!-- Рейс -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="Passport:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding Passport}" Style="{StaticResource TicketHeaderStyle}"/>
                        </StackPanel>
                        
                        <!-- Клас -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="Class:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding ClassDisplay}" Style="{StaticResource TicketHeaderStyle}"/>
                        </StackPanel>
                        
                        <!-- Дата -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="Date:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding DepartureDateString}" Style="{StaticResource TicketHeaderStyle}"/>
                        </StackPanel>
                        
                        <!-- Час -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="Boarding time:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding DepartureTimeString}" Style="{StaticResource TicketHeaderStyle}"/>
                        </StackPanel>
                        
                        <!-- Місце -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="Seat:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding Seat}" Style="{StaticResource TicketHeaderStyle}"/>
                        </StackPanel>
                        
                        <!-- Багаж -->
                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,10">
                            <TextBlock Text="Baggage:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding BaggageDisplay}" Style="{StaticResource TicketHeaderStyle}"/>
                        </StackPanel>
                        
                        <!-- Маршрут -->
                        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,10">
                            <TextBlock Text="From / To:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Style="{StaticResource TicketHeaderStyle}">
                                <Run Text="{Binding DepartureCity}"/>
                                <Run Text=" → "/>
                                <Run Text="{Binding ArrivalCity}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Ціна -->
                        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,10,0,0">
                            <TextBlock Text="Price:" Style="{StaticResource TicketValueStyle}"/>
                            <TextBlock Text="{Binding PriceDisplay}" Style="{StaticResource TicketLargeTextStyle}" Foreground="#4A90E2"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- QR-код (заглушка) -->
                    <Border Grid.Row="2" 
                             
                            CornerRadius="4" 
                            Height="50" 
                            Margin="0,15,0,0">
                        <Grid>
                            <Path Data="{DynamicResource qrcode}" Stretch="Uniform" Fill="{DynamicResource MainColor100}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl> 